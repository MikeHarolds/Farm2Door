# --- Database (required, local and production) ---
# Both local development and production now use PostgreSQL, so the same
# DATABASE_URL format works everywhere. The easiest option (including for
# local development) is a free Neon Postgres database: https://neon.tech
#
#   1. Sign up at neon.tech and create a project (free tier).
#   2. Copy the connection string it gives you (it includes ?sslmode=require).
#   3. Paste it below as DATABASE_URL.
#
# If you would rather run Postgres locally instead of using Neon for local
# development, install PostgreSQL and use a connection string like:
#   DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/farm2market
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/farm2market?sslmode=require

# Replace this before using the portal beyond local testing.
# Generate a strong value with: openssl rand -base64 32
# Required (the app will refuse to start in production without it).
JWT_SECRET=change-this-local-secret-to-a-long-random-value
